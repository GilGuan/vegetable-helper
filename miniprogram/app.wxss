/* 全局样式 */
page {
  background-color: #FFF8E1;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  color: #333333;
  line-height: 1.5;
}

/* 主色调 */
.primary-color {
  color: #4CAF50;
}

.primary-bg {
  background-color: #4CAF50;
}

/* 辅助色 */
.secondary-color {
  color: #81C784;
}

.secondary-bg {
  background-color: #81C784;
}

/* 文字颜色 */
.text-primary {
  color: #333333;
}

.text-secondary {
  color: #999999;
}

.text-hint {
  color: #CCCCCC;
}

/* 背景色 */
.bg-white {
  background-color: #ffffff;
}

.bg-light {
  background-color: #FFF8E1;
}

/* 布局 */
.flex {
  display: flex;
}

.flex-row {
  flex-direction: row;
}

.flex-column {
  flex-direction: column;
}

.flex-wrap {
  flex-wrap: wrap;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-around {
  justify-content: space-around;
}

.align-center {
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 边距 */
.m-10 { margin: 10rpx; }
.m-20 { margin: 20rpx; }
.m-30 { margin: 30rpx; }
.p-10 { padding: 10rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 圆角 */
.rounded {
  border-radius: 8rpx;
}

.rounded-lg {
  border-radius: 16rpx;
}

.rounded-full {
  border-radius: 999rpx;
}

/* 阴影 */
.shadow {
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 按钮 */
.btn {
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
  text-align: center;
  font-size: 14px;
}

.btn-primary {
  background-color: #4CAF50;
  color: #ffffff;
}

.btn-secondary {
  background-color: #81C784;
  color: #ffffff;
}

.btn-outline {
  background-color: transparent;
  border: 1rpx solid #4CAF50;
  color: #4CAF50;
}

/* 卡片 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #EEEEEE;
  margin: 20rpx 0;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  font-size: 14px;
  margin-bottom: 20rpx;
}
