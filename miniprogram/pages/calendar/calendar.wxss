.container {
  min-height: 100vh;
  background-color: #FFF8E1;
}

.month-section {
  background-color: #ffffff;
  padding: 10rpx 0;
}

/* 分类筛选 */
.category-filter {
  background-color: #ffffff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.scroll-view {
  width: 100%;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
}

.category-item {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #f5f5f5;
  transition: all 0.2s;
}

.category-item:last-child {
  margin-right: 0;
}

.category-item.active {
  background-color: #4CAF50;
  color: #ffffff;
}

/* 作物列表 */
.crop-section {
  padding: 0 20rpx 20rpx;
}

.crop-list {
  margin-top: 10rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx !important;
  color: #CCCCCC !important;
}
