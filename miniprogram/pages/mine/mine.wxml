<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-avatar">🌱</view>
    <view class="user-info">
      <text class="user-name">种菜达人</text>
      <view class="location-picker">
        <text class="location-icon">📍</text>
        <picker 
          mode="selector" 
          range="{{provinces}}" 
          value="{{provinceIndex}}" 
          bindchange="onProvinceChange"
        >
          <text class="location-text">{{province}}</text>
          <text class="location-arrow">▼</text>
        </picker>
      </view>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-section">
    <view class="stat-card">
      <text class="stat-value">{{stats.plantingCount}}</text>
      <text class="stat-label">生长中</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.harvestCount}}</text>
      <text class="stat-label">已收获</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.recordCount}}</text>
      <text class="stat-label">打理记录</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <view 
      class="menu-item" 
      wx:for="{{menuList}}" 
      wx:key="id" 
      data-menu="{{item}}"
      bindtap="onMenuTap"
    >
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <text class="menu-name">{{item.name}}</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="about-section">
    <text class="about-text">种菜助手 v1.0.0</text>
    <text class="about-text">让种菜变得简单</text>
  </view>
</view>
