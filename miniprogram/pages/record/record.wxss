.container {
  min-height: 100vh;
  background-color: #FFF8E1;
  padding-bottom: 120rpx;
}

/* 记录列表 */
.record-list {
  padding: 20rpx;
}

.record-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.record-date {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.record-content {
  display: flex;
  flex-direction: column;
}

.record-type {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.type-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.type-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.record-note {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-top: 8rpx;
  padding-left: 44rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 150rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.4);
}

.add-btn text {
  font-size: 60rpx;
  color: #ffffff;
  line-height: 1;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 90%;
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.modal-close {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.type-select {
  margin-bottom: 30rpx;
}

.type-label,
.note-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.type-list {
  display: flex;
  flex-wrap: wrap;
}

.type-item {
  width: calc(25% - 15rpx);
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 0;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.type-item:nth-child(4n) {
  margin-right: 0;
}

.type-item.active {
  background-color: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.type-item .type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-item .type-text {
  font-size: 24rpx;
  color: #666666;
}

.note-input {
  margin-top: 20rpx;
}

.note-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
}

.cancel-btn,
.confirm-btn {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 10rpx;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666666;
}

.confirm-btn {
  background-color: #4CAF50;
  color: #ffffff;
}
