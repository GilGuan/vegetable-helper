<view class="container">
  <!-- 记录列表 -->
  <view class="record-list" wx:if="{{!loading && records.length > 0}}">
    <view class="record-card" wx:for="{{records}}" wx:key="_id">
      <view class="record-date">{{item.dateText}}</view>
      <view class="record-content">
        <view class="record-type">
          <text class="type-icon">{{item.type === 'sowing' ? '🌱' : item.type === 'watering' ? '💧' : item.type === 'fertilizing' ? '🌱' : item.type === 'pest_control' ? '🐛' : '🥬'}}</text>
          <text class="type-name">{{item.typeName}}</text>
        </view>
        <text class="record-note" wx:if="{{item.note}}">{{item.note}}</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && records.length === 0}}">
    <view class="empty-icon">📝</view>
    <text class="empty-title">暂无打理记录</text>
    <text class="empty-hint">点击下方按钮添加记录</text>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="onShowAddModal">
    <text>+</text>
  </view>

  <!-- 添加弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="onHideAddModal">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-title">添加打理记录</text>
        <text class="modal-close" bindtap="onHideAddModal">×</text>
      </view>
      
      <view class="modal-body">
        <view class="type-select">
          <view class="type-label">选择类型</view>
          <view class="type-list">
            <view 
              class="type-item {{selectedType === item.value ? 'active' : ''}}" 
              wx:for="{{careTypes}}" 
              wx:key="value" 
              data-type="{{item.value}}"
              bindtap="onTypeSelect"
            >
              <text class="type-icon">{{item.icon}}</text>
              <text class="type-text">{{item.label}}</text>
            </view>
          </view>
        </view>
        
        <view class="note-input">
          <view class="note-label">备注（可选）</view>
          <textarea 
            class="note-textarea" 
            placeholder="记录一下今天的打理情况..."
            value="{{note}}"
            bindinput="onNoteInput"
            maxlength="200"
          />
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="cancel-btn" bindtap="onHideAddModal">取消</button>
        <button class="confirm-btn" bindtap="onConfirmAdd">确认</button>
      </view>
    </view>
  </view>
</view>
