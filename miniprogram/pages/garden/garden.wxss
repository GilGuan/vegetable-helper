.container {
  min-height: 100vh;
  background-color: #FFF8E1;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background-color: #ffffff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 8rpx;
  margin: 0 10rpx;
}

.filter-item.active {
  background-color: #4CAF50;
  color: #ffffff;
}

/* 种植列表 */
.planting-list {
  padding: 0 20rpx;
}

.planting-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.planting-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.crop-info {
  display: flex;
  align-items: center;
}

.crop-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #f5f5f5;
}

.crop-text {
  display: flex;
  flex-direction: column;
}

.crop-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.planting-date {
  font-size: 24rpx;
  color: #999999;
}

.growth-badge {
  background-color: #E8F5E9;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.growth-days {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 500;
}

.planting-actions {
  display: flex;
  justify-content: space-between;
}

.action-btn {
  flex: 1;
  height: 64rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 10rpx;
}

.record-btn {
  background-color: #4CAF50;
  color: #ffffff;
}

.detail-btn {
  background-color: transparent;
  border: 1rpx solid #4CAF50;
  color: #4CAF50;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 150rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 40rpx;
}

.empty-btn {
  width: 240rpx;
  height: 80rpx;
  background-color: #4CAF50;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.4);
}

.add-btn text {
  font-size: 60rpx;
  color: #ffffff;
  line-height: 1;
}
